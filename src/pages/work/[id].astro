---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((p) => ({ params: { id: p.id }, props: { entry: p } }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const h2s = headings.filter((h) => h.depth === 2);
const d = entry.data;
const isPersonal = d.project === '个人作品';
const media = d.video || d.cover || d.poster;
// 方向色：贯穿整页主色
const dirStyle = `--c:var(--dir-${d.direction}); --c-soft:var(--dir-${d.direction}-soft)`;
---
<Base title={`${d.title} · 彭洋 Max Peng`}>
  <article class="wrap case" style={dirStyle}>
    <a href="/#work" class="case-back">← 返回作品</a>

    <div class="case-metas">
      {isPersonal
        ? <span class="meta meta-personal"><span class="meta-key"></span><span class="dot"></span>个人作品</span>
        : <span class="meta meta-project"><span class="meta-key"></span><span class="dot"></span>{d.project}</span>}
      <span class="meta meta-dir"><span class="meta-key"></span><span class="dot"></span>{d.direction}</span>
    </div>

    <h1>{d.title}</h1>

    <p class="case-role">
      {isPersonal
        ? <span>个人独立项目</span>
        : (d.role
            ? <span>我负责：<b>{d.role}</b></span>
            : <span><i>（待补：你在该项目中的个人职责）</i></span>)}
    </p>

    {media && (
      <div class="case-media">
        {d.video
          ? <video src={d.video} poster={d.poster} controls muted loop playsinline></video>
          : <img src={d.cover || d.poster} alt={d.title} />}
      </div>
    )}

    <div class="prose"><Content /></div>
  </article>

  {h2s.length > 1 && (
    <nav class="toc" aria-label="本文目录">
      <p class="toc-label">目录</p>
      <ul>
        {h2s.map((h) => (
          <li><a href={`#${h.slug}`} class="toc-link" data-slug={h.slug}>{h.text}</a></li>
        ))}
      </ul>
    </nav>
  )}
</Base>

<script is:inline>
  const links = document.querySelectorAll('.toc-link');
  if (links.length) {
    const activate = (slug) => links.forEach((l) => l.classList.toggle('active', l.dataset.slug === slug));
    const io = new IntersectionObserver(
      (entries) => entries.forEach((e) => { if (e.isIntersecting) activate(e.target.id); }),
      { rootMargin: '-5% 0% -72% 0%', threshold: 0 }
    );
    links.forEach((l) => { const el = document.getElementById(l.dataset.slug); if (el) io.observe(el); });
    // 默认高亮第一项
    if (links[0]) activate(links[0].dataset.slug);
  }
</script>
