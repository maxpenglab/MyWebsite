---
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Squiggle from '../components/Squiggle.astro';
import { getCollection } from 'astro:content';

const all = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const featured = all.filter((p) => p.data.featured);
const directions = ['全部', '渲染', '特效', '优化', '动画', '美术流程'];

// —— Hero 线框高度场（构建期生成，静态 SVG）——
const COLS = 17, ROWS = 12, W = 560, H = 440;
const grid: [number, number][][] = [];
for (let j = 0; j < ROWS; j++) {
  const t = j / (ROWS - 1);
  const persp = 0.34 + t * 0.66;
  const rowY = 70 + Math.pow(t, 1.6) * (H - 110);
  const row: [number, number][] = [];
  for (let i = 0; i < COLS; i++) {
    const u = i / (COLS - 1) - 0.5;
    const x = W / 2 + u * W * persp;
    const wave = Math.sin(u * Math.PI * 2.2 + t * 2.6) * (6 + t * 26);
    row.push([+(x).toFixed(1), +(rowY - wave).toFixed(1)]);
  }
  grid.push(row);
}
const hLines = grid.map((row) => row.map((p) => p.join(',')).join(' '));
const vLines: string[] = [];
for (let i = 0; i < COLS; i++) vLines.push(grid.map((row) => row[i].join(',')).join(' '));

// —— 区块间的母题：一片轻微起伏的点阵 + 连线（极淡，填补留白）——
// 同一套生成逻辑；flip 水平镜像 → 第二条母题流向与第一条相反
const MW = 1100;
function buildMotif(MC: number, MR: number, MH: number, flip: boolean) {
  const dots: { x: number; y: number }[] = [];
  const lines: string[] = [];
  for (let r = 0; r < MR; r++) {
    const rowPts: string[] = [];
    for (let c = 0; c < MC; c++) {
      let x = (c / (MC - 1)) * MW;
      const y = MH / 2 + Math.sin(c * 0.5 + r * 0.9) * (6 + r * 4) + (r - MR / 2) * 16;
      if (flip) x = MW - x;
      dots.push({ x: +x.toFixed(1), y: +y.toFixed(1) });
      rowPts.push(`${x.toFixed(1)},${y.toFixed(1)}`);
    }
    lines.push(rowPts.join(' '));
  }
  return { dots, lines };
}
const MH = 150;
const M1 = buildMotif(30, 5, MH, false);    // 精选 ↔ 全部；下方复用同一份数据，镜像交给 CSS
---
<Base title="彭洋 Max Peng · 技术美术">
  <!-- Hero -->
  <section class="wrap hero">
    <div class="hero-watermark" aria-hidden="true">MAXPENG</div>
    <div class="hero-grid">
      <div class="hero-text">
        <div class="hero-hi rise" style="animation-delay:.05s">欢迎来到我的作品集</div>
        <h1 class="rise" style="animation-delay:.12s"><span class="grad">Max Peng</span></h1>
        <div class="hero-role rise" style="animation-delay:.2s">Technical Artist</div>
        <p class="hero-intro rise" style="animation-delay:.28s">
          我是一名技术美术，目前在<b>网易</b>参与《明日之后》《七日世界》等在产项目。
          擅长渲染与性能优化，做<b>能上线的工程级效果</b>而非演示级 demo——参与多项渲染技术研发并成功申请一项专利，
          同时在把 AI 推进到可用的美术生产管线。
        </p>
        <div class="hero-actions rise" style="animation-delay:.36s">
          <a href="#work" class="btn btn-primary">查看作品</a>
          <a href="/resume.pdf" class="btn btn-ghost" download>下载简历</a>
        </div>
      </div>
      <div class="hero-visual rise" style="animation-delay:.3s" aria-hidden="true">
        <svg viewBox={`0 0 ${W} ${H}`} xmlns="http://www.w3.org/2000/svg">
          {vLines.map((pts) => <polyline class="wire-v" points={pts} />)}
          {hLines.map((pts) => <polyline class="wire-h" points={pts} />)}
        </svg>
      </div>
    </div>
  </section>

  <!-- 精选：横向滚动 -->
  <section class="wrap section">
    <div class="section-head reveal">
      <h2>精选</h2>
      <Squiggle variant={0} />
    </div>
    <div class="rail-meta reveal" aria-hidden="true">
      <span class="rail-swipe"><span>向右滑动</span><span class="rail-arrow">→</span></span>
      <span class="rail-scroll"><span>SCROLL</span><span class="hero-scroll-line"></span></span>
    </div>
    <div class="featrail-wrap">
      <div class="featrail" id="featrail">
        {featured.map((p, i) => <ProjectCard id={p.id} index={i} {...p.data} eager />)}
      </div>
    </div>
  </section>

  <!-- 母题分隔：精选 ↔ 全部 -->
  <div class="wrap motif reveal" aria-hidden="true">
    <svg viewBox={`0 0 ${MW} ${MH}`} xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
      {M1.lines.map((pts) => <polyline class="m-line" points={pts} />)}
      {M1.dots.map((d) => <circle class="m-dot" cx={d.x} cy={d.y} r="2.2" />)}
    </svg>
  </div>

  <!-- 全部 + 方向筛选 -->
  <section class="wrap section" id="work">
    <div class="section-head reveal">
      <h2>全部</h2>
      <Squiggle variant={2} />
    </div>
    <div class="filters reveal">
      {directions.map((d, i) => (
        <button class={`filter${i === 0 ? ' active' : ''}`} data-filter={d}>{d}</button>
      ))}
    </div>
    <div class="grid grid-all" id="work-grid">
      {all.map((p, i) => <ProjectCard id={p.id} index={i} {...p.data} />)}
    </div>
  </section>

  <!-- 母题分隔：全部 ↔ 联系我（用上方同一份线框，CSS 左右镜像 + 平移贴右）-->
  <div class="wrap motif motif-rev reveal" aria-hidden="true">
    <svg viewBox={`0 0 ${MW} ${MH}`} xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
      {M1.lines.map((pts) => <polyline class="m-line" points={pts} />)}
      {M1.dots.map((d) => <circle class="m-dot" cx={d.x} cy={d.y} r="2.2" />)}
    </svg>
  </div>

  <!-- 收尾：联系 -->
  <section class="wrap closing reveal">
    <div class="section-head reveal" style="margin-bottom:18px;">
      <h2>联系我</h2>
      <Squiggle variant={1} />
    </div>
    <p>想聊聊渲染、性能，或任何有意思的合作？欢迎随时来邮件。</p>
    <a href="mailto:max_peng@foxmail.com" class="btn btn-primary">max_peng@foxmail.com</a>
  </section>

  <script is:inline>
  (function () {
    function initIndex() {
      const hero = document.querySelector('.hero');
      if (!hero) return; // 仅在首页运行
      // 幂等：同一页面实例只初始化一次（ClientRouter 换页会换新的 .hero 元素，identity 变化才重跑）。
      // 这样可以安全地“既绑 astro:page-load 又首屏直接调用”，不会重复绑定监听器。
      if (window.__indexInited === hero) return;
      window.__indexInited = hero;

      const ctrl = new AbortController();
      const sig  = { signal: ctrl.signal };
      // 离开首页时自动清理所有监听器与 RAF
      document.addEventListener('astro:before-swap', () => ctrl.abort(), { once: true });

      // ── 卡片 3D 磁性倾斜 ──
      document.querySelectorAll('.card').forEach((card) => {
        card.addEventListener('mouseenter', () => card.classList.add('is-tilting'), sig);
        card.addEventListener('mousemove', (e) => {
          const r  = card.getBoundingClientRect();
          const rx = ((e.clientY - r.top)  / r.height - 0.5) * -12;
          const ry = ((e.clientX - r.left) / r.width  - 0.5) * 10;
          card.style.transform = `translateY(-4px) perspective(900px) rotateX(${rx.toFixed(1)}deg) rotateY(${ry.toFixed(1)}deg)`;
        }, sig);
        card.addEventListener('mouseleave', () => { card.classList.remove('is-tilting'); card.style.transform = ''; }, sig);
      });

      // ── 卡片媒体内视差 ──
      document.querySelectorAll('.card').forEach((card) => {
        const media = card.querySelector('.card-media img, .card-media video');
        if (!media) return;
        card.addEventListener('mouseenter', () => { media.style.transition = 'none'; }, sig);
        card.addEventListener('mousemove', (e) => {
          const r = card.getBoundingClientRect();
          const x = ((e.clientX - r.left) / r.width  - 0.5) * 10;
          const y = ((e.clientY - r.top)  / r.height - 0.5) *  7;
          media.style.transform = `scale(1.07) translate(${-x}px, ${-y}px)`;
        }, sig);
        card.addEventListener('mouseleave', () => { media.style.transition = ''; media.style.transform = ''; }, sig);
      });

      // 拖拽精选时重置卡片状态
      const railEl = document.getElementById('featrail');
      if (railEl) {
        railEl.addEventListener('pointerdown', () => {
          railEl.querySelectorAll('.card').forEach((c) => {
            c.classList.remove('is-tilting'); c.style.transform = '';
            const m = c.querySelector('.card-media img, .card-media video');
            if (m) { m.style.transition = ''; m.style.transform = ''; }
          });
        }, sig);
      }

      // ── Hero + Motif 视差（lerp）──
      const heroSec    = document.querySelector('.hero');
      const heroVisual = document.querySelector('.hero-visual');
      const motifSvgs  = [...document.querySelectorAll('.motif svg')].map((svg) => ({
        svg, rev: svg.closest('.motif').classList.contains('motif-rev'),
      }));
      let htx = 0, hty = 0, hcx = 0, hcy = 0, mtx = 0, mcx = 0;
      let alive = true;
      ctrl.signal.addEventListener('abort', () => { alive = false; });
      const tick = () => {
        if (!alive) return;
        hcx += (htx - hcx) * 0.055; hcy += (hty - hcy) * 0.055; mcx += (mtx - mcx) * 0.035;
        if (heroVisual) heroVisual.style.transform = `translate(${hcx * -38}px, ${hcy * -28}px)`;
        // 视差漂移；上方居中(left:50%)，下方贴右镜像(right:0 + scaleX(-1))，与 CSS 基态一致
        motifSvgs.forEach((m) => {
          const dx = (mcx * 50 * (m.rev ? 1 : -1)).toFixed(1);
          m.svg.style.transform = m.rev
            ? `translate(${dx}px, -50%) scaleX(-1)`
            : `translate(calc(-50% + ${dx}px), -50%)`;
        });
        requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
      document.addEventListener('mousemove', (e) => {
        if (heroSec) { const r = heroSec.getBoundingClientRect(); htx = (e.clientX - r.left) / r.width - 0.5; hty = (e.clientY - r.top) / r.height - 0.5; }
        mtx = e.clientX / window.innerWidth - 0.5;
      }, sig);
      document.addEventListener('mouseleave', () => { htx = 0; hty = 0; mtx = 0; }, sig);

      // ── 方向筛选动画 ──
      const buttons = document.querySelectorAll('.filter');
      const cards   = document.querySelectorAll('#work-grid .card');
      const pending = new WeakMap();
      buttons.forEach((btn) => btn.addEventListener('click', () => {
        const f = btn.getAttribute('data-filter');
        buttons.forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        cards.forEach((c) => {
          const show = f === '全部' || c.getAttribute('data-dir') === f;
          const t = pending.get(c); if (t) { clearTimeout(t); pending.delete(c); }
          if (show) {
            c.classList.remove('is-hidden', 'card-exit'); c.classList.add('card-enter');
            pending.set(c, setTimeout(() => c.classList.remove('card-enter'), 400));
          } else if (!c.classList.contains('is-hidden')) {
            c.classList.add('card-exit');
            pending.set(c, setTimeout(() => { c.classList.add('is-hidden'); c.classList.remove('card-exit'); }, 200));
          }
        });
      }, sig));

      // ── 视频 hover 预览 ── play() 成功（已真正开始播放）后再淡入，避免黑帧闪烁
      document.querySelectorAll('.card-media video').forEach((v) => {
        const card = v.closest('.card');
        card.addEventListener('mouseenter', () => {
          v.play().then(() => card.classList.add('is-playing')).catch(() => {});
        }, sig);
        card.addEventListener('mouseleave', () => {
          card.classList.remove('is-playing'); v.pause(); v.currentTime = 0;
        }, sig);
      });

      // ── 视频后台预热 ── 封面（<img>）以最高优先级先出；视频等首屏加载完、且卡片接近视口时
      // 才在后台缓冲（preload=auto + load），这样 hover 即时播放，又不和首屏封面抢带宽、也不无脑下载全部。
      const startWarming = () => {
        const warmIO = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (!e.isIntersecting) return;
            const v = e.target.querySelector('video');
            if (v && v.preload !== 'auto') { v.preload = 'auto'; v.load(); }
            warmIO.unobserve(e.target);
          });
        }, { rootMargin: '400px 0px' });
        document.querySelectorAll('.card-media').forEach((m) => { if (m.querySelector('video')) warmIO.observe(m); });
        ctrl.signal.addEventListener('abort', () => warmIO.disconnect());
      };
      if (document.readyState === 'complete') startWarming();
      else window.addEventListener('load', startWarming, { once: true, ...sig });

      // ── 精选横向拖拽 ──
      const rail = document.getElementById('featrail');
      if (rail) {
        let down = false, startX = 0, startLeft = 0, dragged = false;
        const onMove = (e) => {
          if (!down) return;
          const dx = e.clientX - startX;
          if (Math.abs(dx) > 6) { dragged = true; rail.classList.add('dragging'); }
          if (dragged) { rail.scrollLeft = startLeft - dx; e.preventDefault(); }
        };
        const onUp = () => {
          if (!down) return; down = false; rail.classList.remove('dragging');
          window.removeEventListener('pointermove', onMove); window.removeEventListener('pointerup', onUp);
          if (dragged) {
            const swallow = (ev) => { ev.preventDefault(); ev.stopPropagation(); };
            rail.addEventListener('click', swallow, { capture: true, once: true });
            setTimeout(() => rail.removeEventListener('click', swallow, true), 60);
          }
        };
        rail.addEventListener('pointerdown', (e) => {
          if (e.button !== 0 || e.pointerType !== 'mouse') return;
          down = true; dragged = false; startX = e.clientX; startLeft = rail.scrollLeft;
          window.addEventListener('pointermove', onMove, { passive: false });
          window.addEventListener('pointerup', onUp);
        }, sig);
        rail.addEventListener('dragstart', (e) => e.preventDefault(), sig);
        // 注意：不劫持竖向滚轮。竖向滚轮始终滚页面；横向滚 rail 走触控板横扫（原生）或拖拽。
      }

      // ── 内容淡入 & 手绘线 ──
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
      }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
      // 同步兜底：慢设备上 IO 首次回调会被主线程饿死，卡片长时间停在 opacity:0。
      // page-load 时布局已就绪，立即点亮视口内元素，不等 IO 异步派发（这正是“进详情页再返回就秒出”的原因）。
      const revealInView = () => {
        document.querySelectorAll('.reveal:not(.in)').forEach((el) => {
          const r = el.getBoundingClientRect();
          if (r.bottom > 0 && r.top < window.innerHeight) { el.classList.add('in'); io.unobserve(el); }
        });
      };
      revealInView();
      window.addEventListener('load', revealInView, sig);

      // 画一次即停（与卡片 io 一致的“一次性”模式）。
      // 关键：不要用 toggle——否则同步点亮后被这里的回调反复增删，手绘线会被重置。
      const sqio = new IntersectionObserver((entries) => {
        entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('draw'); sqio.unobserve(e.target); } });
      }, { threshold: 0.6 });
      document.querySelectorAll('.section-head').forEach((el) => sqio.observe(el));
      // 同步兜底：与卡片同理，慢设备上 sqio 首帧回调被饿死会导致首屏手绘线迟迟不画。
      const drawInView = () => {
        document.querySelectorAll('.section-head:not(.draw)').forEach((el) => {
          const r = el.getBoundingClientRect();
          if (r.top < window.innerHeight * 0.9 && r.bottom > 0) { el.classList.add('draw'); sqio.unobserve(el); }
        });
      };
      drawInView();
      window.addEventListener('load', drawInView, sig);

      // 滚动驱动兜底（核心修复）：IntersectionObserver 在首次加载时可能整轮不触发——
      // 已知行为，Safari 尤甚：直到一次滚动/布局变化才被唤醒，期间手绘线/淡入永不发生
      // （这正是“必须进详情页返回才出现”的真因——返回时 IO 被重建并随即触发）。
      // 滚动/resize 事件本身始终可靠，用它驱动点亮，不依赖 IO 是否醒着。rAF 节流。
      let ticking = false;
      const onScroll = () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => { ticking = false; revealInView(); drawInView(); });
      };
      window.addEventListener('scroll', onScroll, { passive: true, ...sig });
      window.addEventListener('resize', onScroll, { passive: true, ...sig });

      // 离开首页时断开观察器，避免跨导航累积
      ctrl.signal.addEventListener('abort', () => { io.disconnect(); sqio.disconnect(); });
    }

    // astro:page-load 覆盖每次 ClientRouter 导航；只注册一次，避免 inline 重跑累积
    if (!window.__indexBound) {
      window.__indexBound = true;
      document.addEventListener('astro:page-load', initIndex);
    }
    // 首屏直接跑一次：首次加载时 astro:page-load 可能在本脚本注册监听器之前就已触发而被错过，
    // 导致整套交互（hover 播放视频、卡片倾斜、筛选、淡入/手绘线）首屏全不生效，必须导航返回才“复活”。
    // 脚本位于 body 末尾，此时所有元素已解析；幂等保护确保不会与 page-load 重复初始化。
    initIndex();
  })();
  </script>
</Base>
