---
import '../styles/global.css';
interface Props { title: string; }
const { title } = Astro.props;
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content="彭洋 Max Peng — 渲染方向技术美术作品集" />
    <script is:inline>document.documentElement.classList.add('js')</script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- 圆润现代无衬线 + 等宽，柔和不生硬 -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <!-- 标题展示体 Clash Grotesk（CDN），加载失败自动回退到 Jakarta -->
    <link href="https://api.fontshare.com/v2/css?f[]=clash-grotesk@500,600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="scroll-progress-track" aria-hidden="true"><span class="scroll-progress-bar" id="scroll-progress"></span></div>
    <header id="site-header">
      <div class="wrap">
        <nav class="nav">
          <a href="/" class="nav-name">Max<b>Peng</b></a>
          <div class="nav-links">
            <a href="/#work">作品</a>
            <a href="/about">关于</a>
            <a href="/resume.pdf" class="nav-cta" download>下载简历</a>
          </div>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="wrap">
      <div class="foot">
        <span>© 2026 彭洋 Max Peng</span>
        <span>max_peng@foxmail.com</span>
      </div>
    </footer>
    <div class="cursor-dot" id="cursor-dot" aria-hidden="true"></div>
    <div class="cursor-ring" id="cursor-ring" aria-hidden="true"></div>
    <script is:inline>
      const bar = document.getElementById('scroll-progress');
      const hdr = document.getElementById('site-header');
      const onScroll = () => {
        const h = document.documentElement;
        const p = h.scrollTop / (h.scrollHeight - h.clientHeight || 1);
        if (bar) bar.style.transform = 'scaleX(' + Math.max(0, Math.min(1, p)) + ')';
        if (hdr) hdr.classList.toggle('scrolled', h.scrollTop > 50);
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();

      // 自定义光标（仅 hover 设备激活）
      if (window.matchMedia('(hover: hover)').matches) {
        const dot  = document.getElementById('cursor-dot');
        const ring = document.getElementById('cursor-ring');
        if (dot && ring) {
          document.body.classList.add('custom-cursor');
          let mx = -200, my = -200, rx = -200, ry = -200;
          document.addEventListener('mousemove', (e) => {
            mx = e.clientX; my = e.clientY;
            dot.style.left = mx + 'px'; dot.style.top = my + 'px';
          });
          // 环以 lerp 弹性跟随，形成拖尾感
          (function lerp() {
            rx += (mx - rx) * 0.11; ry += (my - ry) * 0.11;
            ring.style.left = rx.toFixed(1) + 'px'; ring.style.top = ry.toFixed(1) + 'px';
            requestAnimationFrame(lerp);
          })();
          // hover 链接/按钮：环扩大
          document.querySelectorAll('a, button').forEach((el) => {
            el.addEventListener('mouseenter', () => { if (!ring.classList.contains('is-card')) ring.classList.add('is-link'); });
            el.addEventListener('mouseleave', () => ring.classList.remove('is-link'));
          });
          // hover 卡片：环变圆角矩形
          document.querySelectorAll('.card').forEach((el) => {
            el.addEventListener('mouseenter', () => { ring.classList.remove('is-link'); ring.classList.add('is-card'); });
            el.addEventListener('mouseleave', () => ring.classList.remove('is-card'));
          });
          // 离开页面时隐藏光标
          document.addEventListener('mouseleave', () => { dot.style.opacity = '0'; ring.style.opacity = '0'; });
          document.addEventListener('mouseenter', () => { dot.style.opacity = ''; ring.style.opacity = ''; });
        }
      }
    </script>

  </body>
</html>
